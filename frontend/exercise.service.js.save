  } catch (error) {
    console.error(`❌ Error details:`, {
      status: error.response?.status,
      statusText: error.response?.statusText,
      data: error.response?.data,
      message: error.message
    });
    res.status(error.response?.status || 500).send('Image not found');
  }
});
Changed:
javascript// OLD (with query parameters):
`https://exercisedb.p.rapidapi.com/image/?resolution=360&exerciseId=${id}`

// NEW (simpler path parameter):
`https://exercisedb.p.rapidapi.com/image/${id}`

