javascriptasync searchExerciseGif(exerciseName) {
  try {
    const rapidApiKey = process.env.RAPIDAPI_KEY;
    
    if (!rapidApiKey) {
      console.warn('⚠️ RAPIDAPI_KEY not configured');
      return null;
    }

    // Search for the exercise by name
    const response = await axios.get(
      `https://exercisedb.p.rapidapi.com/exercises/name/${encodeURIComponent(exerciseName.toLowerCase())}`,
      {
        headers: {
          'X-RapidAPI-Key': rapidApiKey,
          'X-RapidAPI-Host': 'exercisedb.p.rapidapi.com'
        },
        timeout: 5000
      }
    );

    if (response.data && response.data.length > 0) {
      const exercise = response.data[0];
      
      // Construct the GIF URL from the exercise ID
      const gifUrl = `https://v2.exercisedb.io/image/${exercise.id}`;
      
      console.log(`✅ Found GIF for ${exerciseName}: ${gifUrl}`);
      return gifUrl;
    }

    console.log(`❌ No exercise found for: ${exerciseName}`);
    return null;

  } catch (error) {
    console.error(`Error searching for ${exerciseName}:`, error.message);
    return null;
  }
}
