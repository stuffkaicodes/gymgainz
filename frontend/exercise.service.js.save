## 🎯 Alternative: Use the Direct GIF URL Pattern

If the endpoint doesn't work, ExerciseDB's GIFs are actually hosted at:
```
https://v2.exercisedb.io/image/{id}
But you need to access them differently. Try this simpler approach:
javascriptasync searchExerciseGif(exerciseName) {
  try {
    const rapidApiKey = process.env.RAPIDAPI_KEY;
    
    if (!rapidApiKey) {
      return null;
    }

    let searchName = exerciseName.toLowerCase().trim()
      .replace(/^dumbbell\s+/i, '')
      .replace(/^barbell\s+/i, '')
      .replace(/^cable\s+/i, '');

    const response = await axios.get(
      `https://exercisedb.p.rapidapi.com/exercises/name/${encodeURIComponent(searchName)}`,
      {
        headers: {
          'X-RapidAPI-Key': rapidApiKey,
          'X-RapidAPI-Host': 'exercisedb.p.rapidapi.com'
        },
        timeout: 5000
      }
    );

    if (response.data && response.data.length > 0) {
      const exercise = response.data[0];
      
      // ExerciseDB stores GIFs with 4-digit IDs padded with zeros
      const paddedId = exercise.id.padStart(4, '0');
      const gifUrl = `https://v2.exercisedb.io/image/${paddedId}`;
      
      console.log(`✅ GIF URL: ${gifUrl}`);
      return gifUrl;
    }

    return null;

  } catch (error) {
    return null;
  }
}

